# Environment (development | production)
APP_ENV=development

# Gemini AI Configuration
GEMINI_API_KEY=your_google_gemini_api_key

# DeepSeek AI Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Binance Mainnet Credentials (USE WITH CAUTION - REAL MONEY)
BINANCE_API_KEY=your_mainnet_api_key
BINANCE_SECRET_KEY=your_mainnet_secret_key
# Optional: Specific keys for Futures if different from Spot
BINANCE_FUTURES_API_KEY=your_futures_mainnet_api_key
BINANCE_FUTURES_SECRET_KEY=your_futures_mainnet_secret_key

# Binance Demo Mode (demo.binance.com)
BINANCE_DEMO_API_KEY=your_demo_api_key
BINANCE_DEMO_SECRET_KEY=your_demo_secret_key

# Binance Testnet Credentials (testnet.binance.vision for Spot)
BINANCE_TESTNET_API_KEY=your_testnet_api_key
BINANCE_TESTNET_SECRET_KEY=your_testnet_secret_key

# Binance Futures Testnet (testnet.binancefuture.com)
# Mandatory for Futures trading in sandbox/testnet mode
BINANCE_FUTURES_TESTNET_API_KEY=your_futures_testnet_api_key
BINANCE_FUTURES_TESTNET_SECRET_KEY=your_futures_testnet_secret_key

# MongoDB Configuration
MONGO_URI=mongodb://admin:securepassword@mongodb:27017/
MONGO_DB_NAME=trading_bot

# Bot Defaults
SYMBOL=BTC/USDT
TIMEFRAME=1h
AMOUNT=100
NETWORK=demo

MAX_CONSECUTIVE_LOSSES=3
CIRCUIT_BREAKER_COOLDOWN=300