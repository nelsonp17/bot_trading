# Environment (development | production)
APP_ENV=development

# Gemini AI Configuration
GEMINI_API_KEY=your_google_gemini_api_key

# DeepSeek AI Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Binance Mainnet Credentials (USE WITH CAUTION - REAL MONEY)
BINANCE_API_KEY=your_mainnet_api_key
BINANCE_SECRET_KEY=your_mainnet_secret_key

# Binance Demo Mode (demo.binance.com)
BINANCE_DEMO_API_KEY=your_demo_api_key
BINANCE_DEMO_SECRET_KEY=your_demo_secret_key

# Binance Testnet Credentials (testnet.binance.vision)
BINANCE_TESTNET_API_KEY=your_testnet_api_key
BINANCE_TESTNET_SECRET_KEY=your_testnet_secret_key

# MongoDB Configuration
MONGO_URI=mongodb://admin:securepassword@mongodb:27017/
MONGO_DB_NAME=trading_bot

# Bot Defaults
SYMBOL=BTC/USDT
TIMEFRAME=1h
AMOUNT=100
NETWORK=demo
